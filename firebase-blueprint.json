{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about the user profile and settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "currency": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Transaction": {
      "title": "Financial Transaction",
      "description": "Represents an income or expense transaction.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The ID of the user who owns this transaction." },
        "amount": { "type": "number", "description": "Transaction amount." },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "amount", "type", "date"]
    },
    "SavingsGoal": {
      "title": "Savings Goal",
      "description": "Represents a goal for saving money.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "targetAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "deadline": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "targetAmount", "currentAmount"]
    },
    "MonthlyBudget": {
      "title": "Monthly Budget",
      "description": "Represents the budget limit for a specific month.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "year": { "type": "number" },
        "month": { "type": "number" },
        "limit": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "year", "month", "limit"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Global user profiles."
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Financial income and expenses."
    },
    "/savings_goals/{goalId}": {
      "schema": "SavingsGoal",
      "description": "User savings goals."
    },
    "/budgets/{budgetId}": {
      "schema": "MonthlyBudget",
      "description": "User monthly budget limits."
    }
  }
}
